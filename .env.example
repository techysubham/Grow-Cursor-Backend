# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Identifies which server instance owns auto-compat batches.
# Set to 'render' in Render's environment variables; leave unset (defaults to 'local') on local dev.
# This prevents a local dev server from stealing batches that Render is processing, and vice versa.
RUNNER_ID=local

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
# Strong random secret for signing JWTs (min 32 chars recommended)
JWT_SECRET=replace_with_a_secure_random_string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
# e.g. https://your-app.vercel.app,https://staging.your-app.vercel.app
CLIENT_ORIGIN=https://your-app.vercel.app

# ─── eBay API ─────────────────────────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Separate key used specifically for AI fitment generation (can be same key)
OPENAI_FITMENT_API_KEY=
# Max concurrent OpenAI requests (default: 3)
OPENAI_CONCURRENT_REQUESTS=3

# ─── ScraperAPI (Amazon product data) ─────────────────────────────────────────
SCRAPER_API_KEY=
# Max concurrent scraper requests (default: 5)
SCRAPER_API_CONCURRENT=5
# Request timeout in milliseconds (default: 60000)
SCRAPER_API_TIMEOUT_MS=60000
# Max retries per request (default: 2)
SCRAPER_API_MAX_RETRIES=2

# ─── ImgBB (image hosting) ────────────────────────────────────────────────────
IMGBB_API_KEY=

# ─── ASIN Cache ───────────────────────────────────────────────────────────────
# Enable in-memory ASIN product cache (true/false)
ENABLE_ASIN_CACHE=true
# Cache TTL in seconds (default: 3600 = 1 hour)
ASIN_CACHE_TTL=3600

# ─── API Usage Tracking ───────────────────────────────────────────────────────
ENABLE_API_USAGE_TRACKING=true

# ─── Bulk Processing ──────────────────────────────────────────────────────────
# Number of ASINs processed per batch in bulk operations (default: 5)
BACKEND_BATCH_SIZE=5
